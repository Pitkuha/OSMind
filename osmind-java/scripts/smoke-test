#!/usr/bin/env sh
set -eu

ROOT=$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)
cd "$ROOT"

mvn -q package
OSMIND_HOME=/tmp/osmind-smoke sh scripts/osmind-cli seed-network-demo >/tmp/osmind-smoke-seed.log
ANSWER=$(OSMIND_HOME=/tmp/osmind-smoke sh scripts/osmind-cli ask "Почему у меня резко вырос сетевой трафик?")
MONITOR=$(OSMIND_HOME=/tmp/osmind-smoke OSMIND_DISABLE_NOTIFICATIONS=true sh scripts/osmind-cli monitor --once)

printf '%s\n' "$ANSWER"
printf '%s\n' "$ANSWER" | grep -q "Question:"
printf '%s\n' "$ANSWER" | grep -q "Short answer:"
printf '%s\n' "$ANSWER" | grep -q "node"
printf '%s\n' "$ANSWER" | grep -q "42 outbound TCP connections"
printf '%s\n' "$MONITOR" | grep -q "A process opened many outbound connections"

test -f core-java/sentinel-ui/target/sentinel-ui-0.1.0-SNAPSHOT.jar
printf 'Smoke test passed.\n'
